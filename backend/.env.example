# Backend environment — copy to .env and fill in your values.
# This file is safe to commit. .env is gitignored.

# ── Neon PostgreSQL ───────────────────────────────────────────────────────────
# Find this in your Neon dashboard → Project → Connection string.
# Make sure to select "Pooled connection" for production use.
DATABASE_URL=postgres://user:password@ep-xxxxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
# Optional — defaults to 8080.
# PORT=8080
